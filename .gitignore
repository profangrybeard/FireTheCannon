# ==============================================================
# Unreal Engine .gitignore  (UE 5.6 — FireTheCannons)
# Based on Epic's standard template, with editor/IDE additions.
# ==============================================================

# --- IDE / editor user files ---
.vs/
.vscode/
.idea/
*.suo
*.user
*.userprefs
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vsconfig

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Compiled object files ---
*.slo
*.lo
*.o
*.obj

# --- Precompiled headers ---
*.gch
*.pch

# --- Compiled dynamic libraries ---
*.so
*.dylib
*.dll

# --- Compiled static libraries ---
*.lai
*.la
*.a
*.lib

# --- Fortran module files ---
*.mod

# --- Executables ---
*.exe
*.out
*.app
*.ipa

# --- Project files generated by the engine ---
*.xcodeproj
*.xcworkspace
*.sln

# --- Precompiled assets (keep source art out of the repo) ---
SourceArt/**/*.png
SourceArt/**/*.tga

# --- Engine-generated binary output ---
Binaries/
Plugins/**/Binaries/

# --- Builds (allow PakBlacklist + icons) ---
Build/*
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!Build/**/*.ico

# --- Built data for maps (regenerated on load) ---
*_BuiltData.uasset

# --- Editor-generated config / cache / intermediates ---
Saved/
Intermediate/
Plugins/**/Intermediate/
DerivedDataCache/

# --- Crash reports & logs ---
*.log
CrashReportClient*/

# --- Backup / temp files ---
*.bak
*.tmp
*.autosave
